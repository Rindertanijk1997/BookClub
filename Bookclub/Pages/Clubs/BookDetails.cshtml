@page "/Clubs/BookDetails/{id:int}"
@model Bookclub.Pages.Clubs.BookDetailsModel
@{
    ViewData["Title"] = Model.ClubBook?.Book?.Title ?? "Bok";
}

<div class="container mt-4">
    <a href="/Clubs/Details/@Model.ClubBook?.ClubId" class="btn btn-outline-secondary mb-3">← Tillbaka</a>

    @if (Model.ClubBook is null)
    {
        <div class="alert alert-danger">Boken hittades inte.</div>
    }
    else
    {
        <div class="mb-4">
            <h1>@Model.ClubBook.Book?.Title</h1>
            <p class="text-muted">@Model.ClubBook.Book?.Author</p>
            <span class="badge bg-secondary">@Model.ClubBook.Status</span>
        </div>

        <div class="card shadow-sm mb-4">
            <div class="card-body">
                <h5 class="card-title mb-3">Diskussion</h5>

                @if (!Model.ClubBook.Discussions.Any())
                {
                    <p class="text-muted">Inga kommentarer än. Var först!</p>
                }
                else
                {
                    <ul class="list-unstyled">
                        @foreach (var d in Model.ClubBook.Discussions.OrderByDescending(x => x.CreatedAt))
                        {
                            <li class="mb-3 pb-3 border-bottom">
                                <div class="d-flex justify-content-between">
                                    <strong>@d.User?.UserName</strong>
                                    <small class="text-muted">@d.CreatedAt.ToString("yyyy-MM-dd HH:mm")</small>
                                </div>
                                <p class="mb-0 mt-1">@d.Text</p>
                            </li>
                        }
                    </ul>
                }

                <form method="post" class="mt-3">
                    <input type="hidden" asp-for="ClubBookId" />
                    <div class="mb-2">
                        <textarea asp-for="NewComment" class="form-control" rows="3" placeholder="Skriv en kommentar..."></textarea>
                    </div>
                    <button type="submit" class="btn btn-primary">Skicka</button>
                </form>
            </div>
        </div>
    }
</div>